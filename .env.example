# =============================================================================
# Environment variables untuk docker-compose / Coolify
# Copy file ini menjadi `.env` (lokal) atau isi langsung di tab "Environment
# Variables" pada Coolify. JANGAN commit file `.env` ke git.
# =============================================================================

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=ganti-password-root-kuat
DB_NAME=mamuri_memberarea
DB_USER=mamuri
DB_PASSWORD=ganti-password-db-kuat

# ---------- Backend (Express) ----------
# Generate random 64+ chars, jangan pakai default.
JWT_SECRET=ganti-jwt-secret-min-64-karakter-acak
JWT_EXPIRES_IN=7d

# Admin pertama; dibuat otomatis saat backend start jika belum ada.
ADMIN_NAME=Admin Mamuri
ADMIN_EMAIL=admin@mamuri.id
ADMIN_PASSWORD=GantiPasswordAdminKuat!

# Tambahan origin yang boleh memanggil API (pisahkan dengan koma).
# Biasanya tidak perlu diisi karena Nginx frontend mem-proxy /api → backend
# (browser → frontend domain → same origin). Isi hanya jika ada domain lain
# yang langsung memanggil API dari browser.
# CORS_ORIGINS=https://staging.mamuri.id,https://www.mamuri.id

# ---------- Frontend (Vite build-time) ----------
# Default `/api` = panggilan relatif, di-proxy Nginx ke service `backend`.
# Ganti ke URL absolut hanya kalau API di-deploy di domain berbeda.
VITE_API_URL=/api
# Origin asal untuk file statis /uploads/. Kosong = pakai origin browser saat ini.
VITE_PUBLIC_ORIGIN=

VITE_OFFICE_ADDRESS=Jl. Satria Deket SPBU Gandul, Kec. Kota Tangerang Selatan, Kota Tangerang Selatan, Banten 15122
VITE_OFFICE_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=!1m16!1m12!1m3!1d495.68253171380223!2d106.79530522024142!3d-6.334373599013597!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!2m1!1ssatria%20deket%20spbu%20gandul!5e0!3m2!1sid!2sid!4v1776208446228!5m2!1sid!2sid
VITE_OFFICE_MAP_LINK=https://www.google.com/maps?q=-6.334373599013597,106.79530522024142
