# Dev: browser memanggil /api → Vite proxy → backend di VITE_DEV_PROXY_TARGET.
VITE_API_URL=/api
# Upload/thumbnail absolut: asal file statis API (sesuaikan dengan proxy).
# Samakan host/port dengan backend/.env PORT.
VITE_PUBLIC_ORIGIN=http://127.0.0.1:3000
# Backend lokal. Cloud sering 404 untuk route baru sampai deploy; ganti https://cloud.mamuri.id bila API sudah sinkron.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:3000
# Jika API production sudah sama versinya, bisa ganti ke https://cloud.mamuri.id dan VITE_PUBLIC_ORIGIN ke origin yang sama.
